# ── AWS ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-north-1

# ── DynamoDB ────────────────────────────────────────────────────────────────
# Set to false to use the local slots.json backend (development / testing)
USE_DYNAMODB=true
DYNAMODB_TABLE=HealthcareSlots

# ── SQS ─────────────────────────────────────────────────────────────────────
# Leave empty to disable SQS (reservations still work without it)
SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/YOUR_ACCOUNT_ID/healthcare-reservations

# ── API authentication ───────────────────────────────────────────────────────
# Change this to a strong random value in production
API_KEY=healthcare-api-key-2024

# ── External APIs ────────────────────────────────────────────────────────────
# WAQI token — get a free one at https://aqicn.org/api/
# Leave as "demo" for limited demo access
WAQI_TOKEN=demo

# Classmate health calculation API
HEALTH_API_URL=https://slc5duy34c.execute-api.us-east-1.amazonaws.com/Prod/calculate

# ── Flask ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_ENV=production
